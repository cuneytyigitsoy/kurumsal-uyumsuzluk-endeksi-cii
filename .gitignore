# =====================================================================
# VERİ GİZLİLİĞİ: Ham veri ve bireysel yorum düzeyindeki dosyalar
# ASLA bu repoya commit edilmemeli (etik onay kapsamı dışına çıkar).
# Sadece toplulaştırılmış/özet sonuç tabloları paylaşılabilir
# (03_CII_SONUC/ ve 06_SONUC_ISTATISTIK/ - bunlar İSTEĞE BAĞLI olarak
# aşağıdaki kurallardan muaf tutulmuştur, elle ekleyebilirsiniz).
# =====================================================================
00_HAM_VERI/*
01_TEMIZ_VERI/*
02_DUYGU_SONUC/*
04_VITRIN_SONUC/*
05_KAPPA/*

# Toplulaştırılmış sonuç klasörlerini isterseniz commit edin;
# .gitkeep dosyaları klasör yapısının GitHub'da görünmesi içindir.
!00_HAM_VERI/.gitkeep
!01_TEMIZ_VERI/.gitkeep
!02_DUYGU_SONUC/.gitkeep
!04_VITRIN_SONUC/.gitkeep
!05_KAPPA/.gitkeep

# Excel/CSV veri dosyaları hiçbir yerde commit edilmesin (güvenlik önlemi)
*.csv
*.xlsx
!03_CII_SONUC/*.csv
!06_SONUC_ISTATISTIK/*.csv
